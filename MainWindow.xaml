                    <Separator Background="#1E3A5F" Margin="0,8,0,12"/>

                    <!-- ══════════════════════════════
                         SECTION EYE TRACKING
                    ═══════════════════════════════════ -->
                    <Border Background="#0D1520" BorderBrush="#00D4FF" BorderThickness="0,0,0,2"
                            Padding="8,6" Margin="0,0,0,8">
                        <TextBlock Text="◉ EYE TRACKING" Foreground="#00D4FF"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                    </Border>

                    <TextBlock Text="TAUX D'ÉCHANTILLONNAGE ET (Hz)" Foreground="#64748B"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                    <ComboBox x:Name="CbEtSampleRate" Margin="0,0,0,8"
                              Background="White" Foreground="Black"
                              BorderBrush="#1E3A5F" FontFamily="Consolas" Height="28"
                              SelectionChanged="CbEtSampleRate_Changed">
                        <ComboBoxItem Content="60 Hz"   Tag="60"/>
                        <ComboBoxItem Content="120 Hz"  Tag="120" IsSelected="True"/>
                        <ComboBoxItem Content="250 Hz"  Tag="250"/>
                        <ComboBoxItem Content="500 Hz"  Tag="500"/>
                        <ComboBoxItem Content="1000 Hz" Tag="1000"/>
                    </ComboBox>

                    <TextBlock Text="RÉSOLUTION ÉCRAN" Foreground="#64748B"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtScreenW" Grid.Column="0"
                                 Background="White" Foreground="Black"
                                 BorderBrush="#1E3A5F" FontFamily="Consolas"
                                 Height="28" Padding="6,4" Text="1920"
                                 PreviewTextInput="TxtSampleRate_PreviewTextInput"/>
                        <TextBlock Grid.Column="1" Text="×" Foreground="#64748B"
                                   FontFamily="Consolas" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtScreenH" Grid.Column="2"
                                 Background="White" Foreground="Black"
                                 BorderBrush="#1E3A5F" FontFamily="Consolas"
                                 Height="28" Padding="6,4" Text="1080"
                                 PreviewTextInput="TxtSampleRate_PreviewTextInput"/>
                    </Grid>

                    <TextBlock Text="MODE DE SORTIE ET" Foreground="#64748B"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                    <ComboBox x:Name="CbEtOutputMode" Margin="0,0,0,6"
                              Background="White" Foreground="Black"
                              BorderBrush="#1E3A5F" FontFamily="Consolas" Height="28"
                              SelectionChanged="CbEtOutputMode_Changed">
                        <ComboBoxItem Content="Fichier"    Tag="File"/>
                        <ComboBoxItem Content="TCP Stream" Tag="TCP"/>
                        <ComboBoxItem Content="UDP Stream" Tag="UDP" IsSelected="True"/>
                    </ComboBox>

                    <StackPanel x:Name="PanelEtFile" Visibility="Collapsed">
                        <TextBlock Text="FICHIER ET" Foreground="#64748B" FontFamily="Consolas"
                                   FontSize="9" FontWeight="Bold" Margin="0,4,0,3"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtEtFilePath" Grid.Column="0"
                                     Background="#0F172A" Foreground="#E2E8F0"
                                     BorderBrush="#1E3A5F" FontFamily="Consolas"
                                     Height="28" Padding="6,4" Text="eyetracking_data.csv"/>
                            <Button Grid.Column="1" Content="…" Click="BtnBrowseEt_Click"
                                    Background="#1E3A5F" Foreground="#E2E8F0"
                                    BorderThickness="0" Margin="3,0,0,0" Height="28"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="PanelEtStream">
                        <TextBlock Text="HÔTE ET" Foreground="#64748B" FontFamily="Consolas"
                                   FontSize="9" FontWeight="Bold" Margin="0,4,0,3"/>
                        <TextBox x:Name="TxtEtHost" Background="#0F172A" Foreground="#E2E8F0"
                                 BorderBrush="#1E3A5F" FontFamily="Consolas"
                                 Height="28" Padding="6,4" Text="127.0.0.1" Margin="0,0,0,4"/>
                        <TextBlock Text="PORT ET" Foreground="#64748B" FontFamily="Consolas"
                                   FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                        <TextBox x:Name="TxtEtPort" Background="#0F172A" Foreground="#E2E8F0"
                                 BorderBrush="#1E3A5F" FontFamily="Consolas"
                                 Height="28" Padding="6,4" Text="9998" Margin="0,0,0,6"/>
                    </StackPanel>

                    <!-- Options Eye Tracking -->
                    <TextBlock Text="COMPORTEMENTS SIMULÉS" Foreground="#64748B"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,4,0,4"/>
                    <CheckBox x:Name="ChkEtSaccades" Foreground="#E2E8F0" FontFamily="Consolas"
                              FontSize="11" Content="Saccades" IsChecked="True" Margin="0,0,0,3"/>
                    <CheckBox x:Name="ChkEtBlinks" Foreground="#E2E8F0" FontFamily="Consolas"
                              FontSize="11" Content="Clignements" IsChecked="True" Margin="0,0,0,3"/>
                    <CheckBox x:Name="ChkEtPupil" Foreground="#E2E8F0" FontFamily="Consolas"
                              FontSize="11" Content="Dilatation pupillaire" IsChecked="True" Margin="0,0,0,6"/>

                    <TextBlock Text="BRUIT ET" Foreground="#64748B"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="38"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="SlEtNoise" Grid.Column="0"
                                Minimum="0" Maximum="1" Value="0.3"
                                ValueChanged="SlEtNoise_Changed"/>
                        <TextBlock x:Name="TxtEtNoiseVal" Grid.Column="1"
                                   Text="0.30" Foreground="#00D4FF"
                                   FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>

                    <!-- LSL Eye Tracking -->
                    <Separator Background="#1E3A60" Margin="0,6,0,6"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="ChkLslEt" Grid.Column="0" Content="LSL ET"
                                  Foreground="#00D4FF" FontFamily="Consolas" FontSize="9"
                                  IsChecked="False" VerticalAlignment="Center" Margin="0,0,6,0"
                                  Checked="ChkLslEt_Changed" Unchecked="ChkLslEt_Changed"/>
                        <TextBox x:Name="TxtLslNameEt" Grid.Column="1"
                                 Background="#0F172A" Foreground="#94A3B8"
                                 BorderBrush="#1E3A5F" FontFamily="Consolas" FontSize="9"
                                 Height="24" Padding="4,2" Text="BioSynth_EyeTracking"/>
                    </Grid>

                    <!-- Bouton Eye Tracking -->
                    <Button x:Name="BtnEtStartStop" Content="▶  DÉMARRER ET"
                            Click="BtnEtStartStop_Click" Height="42"
                            FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                            Background="#0E5A82" Foreground="#00D4FF" BorderThickness="0"
                            Margin="0,0,0,4"/>

                    <!-- Statut ET + compteurs -->
                    <Border Background="#0F172A" BorderBrush="#1E3A5F" BorderThickness="1"
                            Padding="8,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="STATUT" Foreground="#64748B" FontFamily="Consolas"
                                           FontSize="8" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtEtStatus" Text="Prêt"
                                           Foreground="#00D4FF" FontFamily="Consolas" FontSize="10"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="SAMPLES" Foreground="#64748B" FontFamily="Consolas"
                                           FontSize="8" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtEtSampleCount" Text="0"
                                           Foreground="#00D4FF" FontFamily="Consolas"
                                           FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="EVENT" Foreground="#64748B" FontFamily="Consolas"
                                           FontSize="8" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtEtEvent" Text="—"
                                           Foreground="#FBBF24" FontFamily="Consolas"
                                           FontSize="12" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Separator Background="#1E3A5F" Margin="0,8,0,12"/>

                    <!-- ══════════════════════════════
                         SECTION FACE TRACKING
                    ═══════════════════════════════════ -->
                    <Border Background="#1A0D20" BorderBrush="#8B5CF6" BorderThickness="0,0,0,2"
                            Padding="8,6" Margin="0,0,0,8">
                        <TextBlock Text="◈ FACE TRACKING" Foreground="#8B5CF6"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                    </Border>

                    <TextBlock Text="MODE DE STREAM" Foreground="#64748B"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                    <ComboBox x:Name="CbFtMode" Margin="0,0,0,8"
                              Background="White" Foreground="Black"
                              BorderBrush="#1E3A5F" FontFamily="Consolas" Height="28"
                              SelectionChanged="CbFtMode_Changed">
                        <ComboBoxItem Content="Landmarks + Pose + AU" Tag="Face" IsSelected="True"/>
                        <ComboBoxItem Content="Émotions seulement"    Tag="Emotion"/>
                    </ComboBox>

                    <TextBlock Text="TAUX D'ÉCHANTILLONNAGE (Hz)" Foreground="#64748B"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                    <ComboBox x:Name="CbFtSampleRate" Margin="0,0,0,8"
                              Background="White" Foreground="Black"
                              BorderBrush="#1E3A5F" FontFamily="Consolas" Height="28">
                        <ComboBoxItem Content="15 Hz"  Tag="15"/>
                        <ComboBoxItem Content="24 Hz"  Tag="24"/>
                        <ComboBoxItem Content="30 Hz"  Tag="30" IsSelected="True"/>
                        <ComboBoxItem Content="60 Hz"  Tag="60"/>
                        <ComboBoxItem Content="120 Hz" Tag="120"/>
                    </ComboBox>

                    <TextBlock Text="MODE DE SORTIE FT" Foreground="#64748B"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                    <ComboBox x:Name="CbFtOutputMode" Margin="0,0,0,6"
                              Background="White" Foreground="Black"
                              BorderBrush="#1E3A5F" FontFamily="Consolas" Height="28"
                              SelectionChanged="CbFtOutputMode_Changed">
                        <ComboBoxItem Content="Fichier"    Tag="File"/>
                        <ComboBoxItem Content="TCP Stream" Tag="TCP"/>
                        <ComboBoxItem Content="UDP Stream" Tag="UDP" IsSelected="True"/>
                    </ComboBox>

                    <StackPanel x:Name="PanelFtFile" Visibility="Collapsed">
                        <TextBlock Text="FICHIER FT" Foreground="#64748B" FontFamily="Consolas"
                                   FontSize="9" FontWeight="Bold" Margin="0,4,0,3"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtFtFilePath" Grid.Column="0"
                                     Background="#0F172A" Foreground="#E2E8F0"
                                     BorderBrush="#1E3A5F" FontFamily="Consolas"
                                     Height="28" Padding="6,4" Text="face_data.csv"/>
                            <Button Grid.Column="1" Content="…" Click="BtnBrowseFt_Click"
                                    Background="#1E3A5F" Foreground="#E2E8F0"
                                    BorderThickness="0" Margin="3,0,0,0" Height="28"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="PanelFtStream">
                        <TextBlock Text="HÔTE FT" Foreground="#64748B" FontFamily="Consolas"
                                   FontSize="9" FontWeight="Bold" Margin="0,4,0,3"/>
                        <TextBox x:Name="TxtFtHost" Background="#0F172A" Foreground="#E2E8F0"
                                 BorderBrush="#1E3A5F" FontFamily="Consolas"
                                 Height="28" Padding="6,4" Text="127.0.0.1" Margin="0,0,0,4"/>
                        <TextBlock Text="PORT FT" Foreground="#64748B" FontFamily="Consolas"
                                   FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                        <TextBox x:Name="TxtFtPort" Background="#0F172A" Foreground="#E2E8F0"
                                 BorderBrush="#1E3A5F" FontFamily="Consolas"
                                 Height="28" Padding="6,4" Text="9997" Margin="0,0,0,6"/>
                    </StackPanel>

                    <TextBlock Text="OPTIONS" Foreground="#64748B"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,0,0,4"/>
                    <CheckBox x:Name="ChkFtHeadMove" Foreground="#E2E8F0" FontFamily="Consolas"
                              FontSize="11" Content="Mouvement de tête" IsChecked="True" Margin="0,0,0,3"/>
                    <CheckBox x:Name="ChkFtMicro" Foreground="#E2E8F0" FontFamily="Consolas"
                              FontSize="11" Content="Micro-expressions" IsChecked="True" Margin="0,0,0,3"/>

                    <TextBlock Text="DURÉE ÉTAT ÉMOTIONNEL (sec)" Foreground="#64748B"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,4,0,3"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="38"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="SlFtEmoDur" Grid.Column="0"
                                Minimum="1" Maximum="15" Value="4"
                                ValueChanged="SlFtEmoDur_Changed"/>
                        <TextBlock x:Name="TxtFtEmoDurVal" Grid.Column="1"
                                   Text="4.0" Foreground="#8B5CF6"
                                   FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>

                    <TextBlock Text="BRUIT FT" Foreground="#64748B"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="38"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="SlFtNoise" Grid.Column="0"
                                Minimum="0" Maximum="1" Value="0.2"
                                ValueChanged="SlFtNoise_Changed"/>
                        <TextBlock x:Name="TxtFtNoiseVal" Grid.Column="1"
                                   Text="0.20" Foreground="#8B5CF6"
                                   FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>

                    <!-- LSL Face Tracking -->
                    <Separator Background="#3B1F6A" Margin="0,6,0,6"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="ChkLslFt" Grid.Column="0" Content="LSL FT"
                                  Foreground="#A78BFA" FontFamily="Consolas" FontSize="9"
                                  IsChecked="False" VerticalAlignment="Center" Margin="0,0,6,0"
                                  Checked="ChkLslFt_Changed" Unchecked="ChkLslFt_Changed"/>
                        <TextBox x:Name="TxtLslNameFt" Grid.Column="1"
                                 Background="#0F172A" Foreground="#94A3B8"
                                 BorderBrush="#1E3A5F" FontFamily="Consolas" FontSize="9"
                                 Height="24" Padding="4,2" Text="BioSynth_Face"/>
                    </Grid>

                    <!-- Bouton Face Tracking -->
                    <Button x:Name="BtnFtStartStop" Content="▶  DÉMARRER FT"
                            Click="BtnFtStartStop_Click" Height="42"
                            FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                            Background="#3B1F6A" Foreground="#8B5CF6" BorderThickness="0"
                            Margin="0,0,0,4"/>

                    <!-- Statut FT -->
                    <Border Background="#0F172A" BorderBrush="#1E3A5F" BorderThickness="1"
                            Padding="8,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="STATUT" Foreground="#64748B" FontFamily="Consolas"
                                           FontSize="8" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtFtStatus" Text="Prêt"
                                           Foreground="#8B5CF6" FontFamily="Consolas" FontSize="10"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="SAMPLES" Foreground="#64748B" FontFamily="Consolas"
                                           FontSize="8" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtFtSampleCount" Text="0"
                                           Foreground="#8B5CF6" FontFamily="Consolas"
                                           FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="MODE" Foreground="#64748B" FontFamily="Consolas"
                                           FontSize="8" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtFtModeLabel" Text="FACE"
                                           Foreground="#A78BFA" FontFamily="Consolas"
                                           FontSize="12" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══════════════════════════════════════
             PANNEAU DROIT — Visualisation
        ════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Background="#0A0E1A">
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="220"/>
            </Grid.RowDefinitions>

            <!-- Barre du haut -->
            <Border Grid.Row="0" Background="#111827" BorderBrush="#1E3A5F" BorderThickness="0,0,0,1">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="OSCILLOSCOPE EEG" Foreground="#00FF88"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtChannelInfo" Text="  8CH·256Hz"
                                   Foreground="#64748B" FontFamily="Consolas" FontSize="10"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="RecDotEeg" Width="7" Height="7"
                                 Fill="#00FF88" Margin="0,0,4,0" Opacity="0"/>
                        <TextBlock x:Name="TxtRecLabel" Text="EEG IDLE"
                                   Foreground="#64748B" FontFamily="Consolas" FontSize="10"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Ellipse x:Name="RecDotEt" Width="7" Height="7"
                                 Fill="#00D4FF" Margin="0,0,4,0" Opacity="0"/>
                        <TextBlock x:Name="TxtEtRecLabel" Text="ET IDLE"
                                   Foreground="#64748B" FontFamily="Consolas" FontSize="10"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Ellipse x:Name="RecDotFt" Width="7" Height="7"
                                 Fill="#8B5CF6" Margin="0,0,4,0" Opacity="0"/>
                        <TextBlock x:Name="TxtFtRecLabel" Text="FT IDLE"
                                   Foreground="#64748B" FontFamily="Consolas" FontSize="10"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Zone EEG oscilloscope + TopoMap + ET + FT -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="200"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <!-- Oscilloscope EEG -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Background="#0A0E1A">
                    <ItemsControl x:Name="EEGPlotsPanel" Background="#0A0E1A"/>
                </ScrollViewer>

                <!-- Panneau Eye Tracking -->
                <Border Grid.Column="1" Background="#0D1520" BorderBrush="#1E3A5F" BorderThickness="1,0,0,0">
                    <StackPanel>
                        <!-- Titre ET -->
                        <Border Background="#111827" BorderBrush="#1E3A5F" BorderThickness="0,0,0,1"
                                Padding="12,8">
                            <TextBlock Text="◉ EYE TRACKING" Foreground="#00D4FF"
                                       FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                        </Border>

                        <!-- Gaze Map -->
                        <Border Padding="8">
                            <StackPanel>
                                <TextBlock Text="CARTE DU REGARD" Foreground="#64748B"
                                           FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                                <Border BorderBrush="#1E3A5F" BorderThickness="1"
                                        Background="#060D18" Height="160">
                                    <Canvas x:Name="GazeMapCanvas" Background="Transparent">
                                        <!-- Grille -->
                                        <Line X1="0" Y1="80" X2="400" Y2="80"
                                              Stroke="#0F2040" StrokeThickness="0.5"/>
                                        <Line X1="152" Y1="0" X2="152" Y2="160"
                                              Stroke="#0F2040" StrokeThickness="0.5"/>
                                        <!-- Point de regard (déplacé par code) -->
                                        <Ellipse x:Name="GazeDot" Width="12" Height="12"
                                                 Fill="#00D4FF" Opacity="0.9"/>
                                        <!-- Traîne (heatmap simplifiée) -->
                                        <Ellipse x:Name="GazeTrail1" Width="8" Height="8"
                                                 Fill="#00D4FF" Opacity="0.4"/>
                                        <Ellipse x:Name="GazeTrail2" Width="6" Height="6"
                                                 Fill="#00D4FF" Opacity="0.25"/>
                                        <Ellipse x:Name="GazeTrail3" Width="4" Height="4"
                                                 Fill="#00D4FF" Opacity="0.12"/>
                                    </Canvas>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Données numériques -->
                        <Border Padding="8,0,8,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="GAZE X" Foreground="#64748B" FontFamily="Consolas"
                                               FontSize="9" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="TxtGazeX" Text="—"
                                               Foreground="#00D4FF" FontFamily="Consolas"
                                               FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Text="GAZE Y" Foreground="#64748B" FontFamily="Consolas"
                                               FontSize="9" Margin="0,6,0,2"/>
                                    <TextBlock x:Name="TxtGazeY" Text="—"
                                               Foreground="#00D4FF" FontFamily="Consolas"
                                               FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Text="ÉVÉNEMENT" Foreground="#64748B" FontFamily="Consolas"
                                               FontSize="9" Margin="0,6,0,2"/>
                                    <TextBlock x:Name="TxtEtEventDetail" Text="—"
                                               Foreground="#FBBF24" FontFamily="Consolas"
                                               FontSize="12" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="PUPILLE G (mm)" Foreground="#64748B"
                                               FontFamily="Consolas" FontSize="9" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="TxtPupilL" Text="—"
                                               Foreground="#8B5CF6" FontFamily="Consolas"
                                               FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Text="PUPILLE D (mm)" Foreground="#64748B"
                                               FontFamily="Consolas" FontSize="9" Margin="0,6,0,2"/>
                                    <TextBlock x:Name="TxtPupilR" Text="—"
                                               Foreground="#8B5CF6" FontFamily="Consolas"
                                               FontSize="13" FontWeight="Bold"/>
                                    <TextBlock Text="VITESSE (°/s)" Foreground="#64748B"
                                               FontFamily="Consolas" FontSize="9" Margin="0,6,0,2"/>
                                    <TextBlock x:Name="TxtEtVelocity" Text="—"
                                               Foreground="#FF4444" FontFamily="Consolas"
                                               FontSize="12" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Graphiques pupille -->
                        <Border Padding="8,0,8,0">
                            <StackPanel>
                                <TextBlock Text="DIAMÈTRE PUPILLAIRE" Foreground="#64748B"
                                           FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                                <Border BorderBrush="#1E3A5F" BorderThickness="1"
                                        Background="#060D18" Height="80">
                                    <Canvas x:Name="PupilCanvas" Background="Transparent">
                                        <Polyline x:Name="PupilLineL"
                                                  Stroke="#8B5CF6" StrokeThickness="1.5"
                                                  StrokeLineJoin="Round"/>
                                        <Polyline x:Name="PupilLineR"
                                                  Stroke="#EC4899" StrokeThickness="1.5"
                                                  StrokeLineJoin="Round"/>
                                    </Canvas>
                                </Border>
                                <!-- Légende -->
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <Ellipse Width="8" Height="8" Fill="#8B5CF6" Margin="0,0,4,0"/>
                                    <TextBlock Text="Gauche" Foreground="#64748B"
                                               FontFamily="Consolas" FontSize="9" Margin="0,0,12,0"/>
                                    <Ellipse Width="8" Height="8" Fill="#EC4899" Margin="0,0,4,0"/>
                                    <TextBlock Text="Droite" Foreground="#64748B"
                                               FontFamily="Consolas" FontSize="9"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- Panneau Face Tracking -->
                <Border Grid.Column="2" Background="#120D1A" BorderBrush="#1E3A5F" BorderThickness="1,0,0,0">
                    <StackPanel>
                        <!-- Titre FT -->
                        <Border Background="#111827" BorderBrush="#1E3A5F" BorderThickness="0,0,0,1"
                                Padding="12,8">
                            <TextBlock Text="◈ FACE TRACKING" Foreground="#8B5CF6"
                                       FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                        </Border>

                        <!-- Visualisation visage (landmarks 2D) -->
                        <Border Padding="8">
                            <StackPanel>
                                <TextBlock Text="LANDMARKS 68pts" Foreground="#64748B"
                                           FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                                <Border BorderBrush="#2D1B4E" BorderThickness="1"
                                        Background="#08040F" Height="160">
                                    <Canvas x:Name="FaceCanvas" Background="Transparent">
                                        <!-- Points générés dynamiquement par code -->
                                    </Canvas>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Pose tête -->
                        <Border Padding="8,0,8,6">
                            <StackPanel>
                                <TextBlock Text="POSE TÊTE (6-DOF)" Foreground="#64748B"
                                           FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="PITCH" Foreground="#64748B" FontFamily="Consolas" FontSize="8"/>
                                        <TextBlock x:Name="TxtFtPitch" Text="0.0°"
                                                   Foreground="#A78BFA" FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Text="YAW" Foreground="#64748B" FontFamily="Consolas" FontSize="8" Margin="0,3,0,0"/>
                                        <TextBlock x:Name="TxtFtYaw" Text="0.0°"
                                                   Foreground="#A78BFA" FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="ROLL" Foreground="#64748B" FontFamily="Consolas" FontSize="8"/>
                                        <TextBlock x:Name="TxtFtRoll" Text="0.0°"
                                                   Foreground="#A78BFA" FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Text="PROF." Foreground="#64748B" FontFamily="Consolas" FontSize="8" Margin="0,3,0,0"/>
                                        <TextBlock x:Name="TxtFtZ" Text="650mm"
                                                   Foreground="#A78BFA" FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="CONF." Foreground="#64748B" FontFamily="Consolas" FontSize="8"/>
                                        <TextBlock x:Name="TxtFtConf" Text="—"
                                                   Foreground="#00FF88" FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Text="MICRO" Foreground="#64748B" FontFamily="Consolas" FontSize="8" Margin="0,3,0,0"/>
                                        <TextBlock x:Name="TxtFtMicro" Text="—"
                                                   Foreground="#FBBF24" FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Émotion dominante + barres -->
                        <Border Padding="8,0,8,6">
                            <StackPanel>
                                <TextBlock Text="ÉTAT ÉMOTIONNEL" Foreground="#64748B"
                                           FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"/>

                                <!-- Badge émotion dominante -->
                                <Border x:Name="FtEmoBadge" Background="#1A1030"
                                        BorderBrush="#8B5CF6" BorderThickness="1"
                                        Padding="8,4" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="TxtFtEmoLabel" Text="NEUTRAL"
                                                   Foreground="#8B5CF6" FontFamily="Consolas"
                                                   FontSize="13" FontWeight="Bold"/>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="AROUSAL" Foreground="#64748B" FontFamily="Consolas" FontSize="7"/>
                                            <TextBlock x:Name="TxtFtArousal" Text="—"
                                                       Foreground="#FBBF24" FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                                            <TextBlock Text="VALENCE" Foreground="#64748B" FontFamily="Consolas" FontSize="7" Margin="0,2,0,0"/>
                                            <TextBlock x:Name="TxtFtValence" Text="—"
                                                       Foreground="#00D4FF" FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Barres émotions -->
                                <ItemsControl x:Name="FtEmoBarsPanel"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>
            </Grid>

            <!-- Barre du bas — Spectral EEG + stats ET + stats FT -->
            <Border Grid.Row="2" Background="#111827" BorderBrush="#1E3A5F"
                    BorderThickness="0,1,0,0" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <!-- Bandes EEG -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="BANDES DE FRÉQUENCE EEG" Foreground="#64748B"
                                   FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="δ DELTA 0.5-4Hz" Foreground="#64748B"
                                           FontFamily="Consolas" FontSize="9" Margin="0,0,0,3"/>
                                <ProgressBar x:Name="PbDelta" Height="10"
                                             Background="#1A2235" Foreground="#8B5CF6"
                                             BorderThickness="0" Maximum="100"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,6,0">
                                <TextBlock Text="θ THETA 4-8Hz" Foreground="#64748B"
                                           FontFamily="Consolas" FontSize="9" Margin="0,0,0,3"/>
                                <ProgressBar x:Name="PbTheta" Height="10"
                                             Background="#1A2235" Foreground="#00D4FF"
                                             BorderThickness="0" Maximum="100"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,6,0">
                                <TextBlock Text="α ALPHA 8-13Hz" Foreground="#64748B"
                                           FontFamily="Consolas" FontSize="9" Margin="0,0,0,3"/>
                                <ProgressBar x:Name="PbAlpha" Height="10"
                                             Background="#1A2235" Foreground="#00FF88"
                                             BorderThickness="0" Maximum="100"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="0,0,6,0">
                                <TextBlock Text="β BETA 13-30Hz" Foreground="#64748B"
                                           FontFamily="Consolas" FontSize="9" Margin="0,0,0,3"/>
                                <ProgressBar x:Name="PbBeta" Height="10"
                                             Background="#1A2235" Foreground="#FBBF24"
                                             BorderThickness="0" Maximum="100"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="γ GAMMA 30-80Hz" Foreground="#64748B"
                                           FontFamily="Consolas" FontSize="9" Margin="0,0,0,3"/>
                                <ProgressBar x:Name="PbGamma" Height="10"
                                             Background="#1A2235" Foreground="#FF4444"
                                             BorderThickness="0" Maximum="100"/>
                            </StackPanel>
                        </Grid>

                        <!-- Stats combinées -->
                        <Border Background="#0F172A" BorderBrush="#1E3A5F" BorderThickness="1"
                                Margin="0,12,0,0" Padding="10,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="EEG" Foreground="#64748B"
                                               FontFamily="Consolas" FontSize="8" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtEegActiveLabel" Text="NON"
                                               Foreground="#FF4444" FontFamily="Consolas"
                                               FontSize="13" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="ET" Foreground="#64748B"
                                               FontFamily="Consolas" FontSize="8" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtEtActiveLabel" Text="NON"
                                               Foreground="#FF4444" FontFamily="Consolas"
                                               FontSize="13" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="FT" Foreground="#64748B"
                                               FontFamily="Consolas" FontSize="8" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtFtActiveLabel" Text="NON"
                                               Foreground="#FF4444" FontFamily="Consolas"
                                               FontSize="13" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="REPLAY" Foreground="#64748B"
                                               FontFamily="Consolas" FontSize="8" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtReplayActiveLabel" Text="NON"
                                               Foreground="#FF4444" FontFamily="Consolas"
                                               FontSize="13" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="SYNC" Foreground="#64748B"
                                               FontFamily="Consolas" FontSize="8" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtSyncLabel" Text="—"
                                               Foreground="#64748B" FontFamily="Consolas"
                                               FontSize="13" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Stats Eye Tracking -->
                    <Border Grid.Column="1" Background="#0D1520" BorderBrush="#1E3A5F"
                            BorderThickness="1,0,0,0" Padding="12,0,0,0">
                        <StackPanel>
                            <TextBlock Text="STATISTIQUES EYE TRACKING" Foreground="#64748B"
                                       FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                                       Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="FIXATIONS" Foreground="#64748B"
                                               FontFamily="Consolas" FontSize="9"/>
                                    <TextBlock x:Name="TxtFixationCount" Text="0"
                                               Foreground="#00FF88" FontFamily="Consolas"
                                               FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="SACCADES" Foreground="#64748B"
                                               FontFamily="Consolas" FontSize="9" Margin="0,6,0,0"/>
                                    <TextBlock x:Name="TxtSaccadeCount" Text="0"
                                               Foreground="#FBBF24" FontFamily="Consolas"
                                               FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="CLIGNEMENTS" Foreground="#64748B"
                                               FontFamily="Consolas" FontSize="9"/>
                                    <TextBlock x:Name="TxtBlinkCount" Text="0"
                                               Foreground="#EC4899" FontFamily="Consolas"
                                               FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="VIT. MOY (°/s)" Foreground="#64748B"
                                               FontFamily="Consolas" FontSize="9" Margin="0,6,0,0"/>
                                    <TextBlock x:Name="TxtAvgVelocity" Text="0"
                                               Foreground="#FF4444" FontFamily="Consolas"
                                               FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Stats Face Tracking -->
                    <Border Grid.Column="2" Background="#120D1A" BorderBrush="#1E3A5F"
                            BorderThickness="1,0,0,0" Padding="12,0,0,0">
                        <StackPanel>
                            <TextBlock Text="STATISTIQUES FACE TRACKING" Foreground="#64748B"
                                       FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                                       Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="ÉMOTION DOM." Foreground="#64748B"
                                               FontFamily="Consolas" FontSize="9"/>
                                    <TextBlock x:Name="TxtFtDomEmo" Text="NEUTRAL"
                                               Foreground="#8B5CF6" FontFamily="Consolas"
                                               FontSize="12" FontWeight="Bold"/>
                                    <TextBlock Text="TRANSITIONS" Foreground="#64748B"
                                               FontFamily="Consolas" FontSize="9" Margin="0,6,0,0"/>
                                    <TextBlock x:Name="TxtFtTransCount" Text="0"
                                               Foreground="#A78BFA" FontFamily="Consolas"
                                               FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="AROUSAL MOY" Foreground="#64748B"
                                               FontFamily="Consolas" FontSize="9"/>
                                    <TextBlock x:Name="TxtFtAvgArousal" Text="—"
                                               Foreground="#FBBF24" FontFamily="Consolas"
                                               FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="VALENCE MOY" Foreground="#64748B"
                                               FontFamily="Consolas" FontSize="9" Margin="0,6,0,0"/>
                                    <TextBlock x:Name="TxtFtAvgValence" Text="—"
                                               Foreground="#00D4FF" FontFamily="Consolas"
                                               FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
