<Window x:Class="BioSynth.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EEG + Eye Tracking Simulator"
        Height="960" Width="1600"
        Background="#0A0E1A"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="310"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════
             PANNEAU GAUCHE — Configuration
        ════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="#111827" BorderBrush="#1E3A5F" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16,20,16,20">

                    <!-- Titre -->
                    <TextBlock Text="⬡ NEURO SIMULATOR" Foreground="#00FF88"
                               FontFamily="Consolas" FontSize="13" FontWeight="Bold"/>
                    <TextBlock Text="EEG + Eye Tracking" Foreground="#64748B"
                               FontFamily="Consolas" FontSize="10" Margin="0,2,0,12"/>

                    <Separator Background="#1E3A5F" Margin="0,0,0,12"/>

                    <!-- ══════════════════════════════
                         SECTION EEG
                    ═══════════════════════════════════ -->
                    <Border Background="#0D1F0D" BorderBrush="#00FF88" BorderThickness="0,0,0,2"
                            Padding="8,6" Margin="0,0,0,8">
                        <TextBlock Text="▶ EEG" Foreground="#00FF88"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                    </Border>

                    <TextBlock Text="CANAUX" Foreground="#64748B" FontFamily="Consolas"
                               FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                    <ComboBox x:Name="CbChannels" Margin="0,0,0,8"
                              Background="White" Foreground="Black"
                              BorderBrush="#1E3A5F" FontFamily="Consolas" Height="28"
                              SelectionChanged="CbChannels_SelectionChanged">
                        <ComboBoxItem Content="8 canaux"  Tag="8"  IsSelected="True"/>
                        <ComboBoxItem Content="16 canaux" Tag="16"/>
                        <ComboBoxItem Content="32 canaux" Tag="32"/>
                        <ComboBoxItem Content="64 canaux" Tag="64"/>
                    </ComboBox>

                    <TextBlock Text="TAUX D'ÉCHANTILLONNAGE (Hz)" Foreground="#64748B"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtSampleRate" Margin="0,0,0,3"
                             Background="White" Foreground="Black"
                             BorderBrush="#1E3A5F" FontFamily="Consolas"
                             Height="28" Padding="6,4" Text="256"
                             PreviewTextInput="TxtSampleRate_PreviewTextInput"/>
                    <TextBlock Text="Typique : 128, 256, 512, 1024, 2048"
                               Foreground="#475569" FontFamily="Consolas" FontSize="9"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="MODE DE SORTIE EEG" Foreground="#64748B"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                    <ComboBox x:Name="CbOutputMode" Margin="0,0,0,6"
                              Background="White" Foreground="Black"
                              BorderBrush="#1E3A5F" FontFamily="Consolas" Height="28"
                              SelectionChanged="CbOutputMode_Changed">
                        <ComboBoxItem Content="Fichier"    Tag="File" IsSelected="True"/>
                        <ComboBoxItem Content="TCP Stream" Tag="TCP"/>
                        <ComboBoxItem Content="UDP Stream" Tag="UDP"/>
                    </ComboBox>

                    <StackPanel x:Name="PanelFile">
                        <TextBlock Text="FICHIER EEG" Foreground="#64748B" FontFamily="Consolas"
                                   FontSize="9" FontWeight="Bold" Margin="0,4,0,3"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtFilePath" Grid.Column="0"
                                     Background="#0F172A" Foreground="#E2E8F0"
                                     BorderBrush="#1E3A5F" FontFamily="Consolas"
                                     Height="28" Padding="6,4" Text="eeg_data.csv"/>
                            <Button Grid.Column="1" Content="…" Click="BtnBrowse_Click"
                                    Background="#1E3A5F" Foreground="#E2E8F0"
                                    BorderThickness="0" Margin="3,0,0,0" Height="28"/>
                        </Grid>
                        <TextBlock Text="FORMAT" Foreground="#64748B" FontFamily="Consolas"
                                   FontSize="9" FontWeight="Bold" Margin="0,6,0,3"/>
                        <ComboBox x:Name="CbFormat" Margin="0,0,0,6"
                                  Background="White" Foreground="Black"
                                  BorderBrush="#1E3A5F" FontFamily="Consolas" Height="28">
                            <ComboBoxItem Content="CSV"            Tag="CSV"    IsSelected="True"/>
                            <ComboBoxItem Content="Binary Float32" Tag="Binary"/>
                            <ComboBoxItem Content="BDF"            Tag="BDF"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel x:Name="PanelStream" Visibility="Collapsed">
                        <TextBlock Text="HÔTE EEG" Foreground="#64748B" FontFamily="Consolas"
                                   FontSize="9" FontWeight="Bold" Margin="0,4,0,3"/>
                        <TextBox x:Name="TxtHost" Background="#0F172A" Foreground="#E2E8F0"
                                 BorderBrush="#1E3A5F" FontFamily="Consolas"
                                 Height="28" Padding="6,4" Text="127.0.0.1" Margin="0,0,0,4"/>
                        <TextBlock Text="PORT EEG" Foreground="#64748B" FontFamily="Consolas"
                                   FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                        <TextBox x:Name="TxtPort" Background="#0F172A" Foreground="#E2E8F0"
                                 BorderBrush="#1E3A5F" FontFamily="Consolas"
                                 Height="28" Padding="6,4" Text="9999" Margin="0,0,0,6"/>
                    </StackPanel>

                    <TextBlock Text="NIVEAU DE BRUIT EEG" Foreground="#64748B"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="38"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="SlNoise" Grid.Column="0"
                                Minimum="0" Maximum="1" Value="0.5"
                                ValueChanged="SlNoise_Changed"/>
                        <TextBlock x:Name="TxtNoiseVal" Grid.Column="1"
                                   Text="0.50" Foreground="#00FF88"
                                   FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>

                    <CheckBox x:Name="ChkArtifacts" Foreground="#E2E8F0"
                              FontFamily="Consolas" FontSize="11"
                              Content="Générer artifacts EEG" IsChecked="True" Margin="0,0,0,8"/>

                    <TextBlock Text="CANAUX AFFICHÉS" Foreground="#64748B"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                    <Slider x:Name="SlDisplayChannels" Minimum="1" Maximum="64" Value="4"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            Margin="0,0,0,2" ValueChanged="SlDisplayChannels_Changed"/>
                    <TextBlock x:Name="TxtDisplayChannels" Text="4 canaux affichés"
                               Foreground="#64748B" FontFamily="Consolas" FontSize="10" Margin="0,0,0,8"/>


                    <Separator Background="#1E3A5F" Margin="0,8,0,8"/>

                    <!-- ══════════════════════════════
                         ZONES CÉRÉBRALES + ÉTAT MENTAL
                    ═══════════════════════════════════ -->
                    <Border Background="#0D1A0D" BorderBrush="#00FF88" BorderThickness="0,0,0,1"
                            Padding="8,5" Margin="0,0,0,8">
                        <TextBlock Text="⬡ ZONES CÉRÉBRALES" Foreground="#00FF88"
                                   FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                    </Border>

                    <!-- Preset état mental -->
                    <TextBlock Text="ÉTAT MENTAL PRÉDÉFINI" Foreground="#64748B"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="CbBrainPreset" Grid.Column="0"
                                  Background="White" Foreground="Black"
                                  BorderBrush="#1E3A5F" FontFamily="Consolas" Height="28">
                            <ComboBoxItem Content="Repos"           Tag="Repos"          IsSelected="True"/>
                            <ComboBoxItem Content="Concentration"   Tag="Concentration"/>
                            <ComboBoxItem Content="Méditation"      Tag="Méditation"/>
                            <ComboBoxItem Content="Éveil"           Tag="Éveil"/>
                            <ComboBoxItem Content="Sommeil léger"   Tag="Sommeil léger"/>
                            <ComboBoxItem Content="Sommeil profond" Tag="Sommeil profond"/>
                        </ComboBox>
                        <Button Grid.Column="1" Content="Appliquer" Margin="4,0,0,0" Height="28"
                                Click="BtnApplyPreset_Click"
                                Background="#1E3A5F" Foreground="#E2E8F0"
                                BorderThickness="0" FontFamily="Consolas" FontSize="9"
                                Cursor="Hand"/>
                    </Grid>

                    <!-- Sliders par zone -->
                    <TextBlock Text="ACTIVATION PAR RÉGION" Foreground="#64748B"
                               FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,0,0,4"/>

                    <!-- Frontal -->
                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Frontal" Foreground="#64C8FF"
                                   FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                        <Slider x:Name="SlZoneFrontal" Grid.Column="1" Minimum="0" Maximum="1" Value="0.5"
                                ValueChanged="SlZone_Changed"/>
                        <TextBlock x:Name="TxtZoneFrontal" Grid.Column="2" Text=".50"
                                   Foreground="#64C8FF" FontFamily="Consolas" FontSize="9"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>

                    <!-- Préfrontal -->
                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Préfrontal" Foreground="#50B4FF"
                                   FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                        <Slider x:Name="SlZonePrefrontal" Grid.Column="1" Minimum="0" Maximum="1" Value="0.5"
                                ValueChanged="SlZone_Changed"/>
                        <TextBlock x:Name="TxtZonePrefrontal" Grid.Column="2" Text=".50"
                                   Foreground="#50B4FF" FontFamily="Consolas" FontSize="9"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>

                    <!-- Central -->
                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Central" Foreground="#00FF88"
                                   FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                        <Slider x:Name="SlZoneCentral" Grid.Column="1" Minimum="0" Maximum="1" Value="0.5"
                                ValueChanged="SlZone_Changed"/>
                        <TextBlock x:Name="TxtZoneCentral" Grid.Column="2" Text=".50"
                                   Foreground="#00FF88" FontFamily="Consolas" FontSize="9"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>

                    <!-- Temporal -->
                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Temporal" Foreground="#FFA500"
                                   FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                        <Slider x:Name="SlZoneTemporal" Grid.Column="1" Minimum="0" Maximum="1" Value="0.5"
                                ValueChanged="SlZone_Changed"/>
                        <TextBlock x:Name="TxtZoneTemporal" Grid.Column="2" Text=".50"
                                   Foreground="#FFA500" FontFamily="Consolas" FontSize="9"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>

                    <!-- Pariétal -->
                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Pariétal" Foreground="#8B5CF6"
                                   FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                        <Slider x:Name="SlZoneParietal" Grid.Column="1" Minimum="0" Maximum="1" Value="0.5"
                                ValueChanged="SlZone_Changed"/>
                        <TextBlock x:Name="TxtZoneParietal" Grid.Column="2" Text=".50"
                                   Foreground="#8B5CF6" FontFamily="Consolas" FontSize="9"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>

                    <!-- Occipital -->
                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Occipital" Foreground="#FF4444"
                                   FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                        <Slider x:Name="SlZoneOccipital" Grid.Column="1" Minimum="0" Maximum="1" Value="0.5"
                                ValueChanged="SlZone_Changed"/>
                        <TextBlock x:Name="TxtZoneOccipital" Grid.Column="2" Text=".50"
                                   Foreground="#FF4444" FontFamily="Consolas" FontSize="9"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>

                    <!-- Fronto-Central -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="FC" Foreground="#C8E664"
                                   FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                        <Slider x:Name="SlZoneFC" Grid.Column="1" Minimum="0" Maximum="1" Value="0.5"
                                ValueChanged="SlZone_Changed"/>
                        <TextBlock x:Name="TxtZoneFC" Grid.Column="2" Text=".50"
                                   Foreground="#C8E664" FontFamily="Consolas" FontSize="9"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>

                    <!-- Bouton TopoMap 2D -->
                    <Button x:Name="BtnOpenTopoMap" Content="🗺  TOPOMAP 2D"
                            Click="BtnOpenTopoMap_Click" Height="36"
                            FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                            Background="#0D2040" Foreground="#00D4FF" BorderThickness="1"
                            BorderBrush="#1E4080" Margin="0,0,0,4" Cursor="Hand"/>

                    <!-- Mode source EEG : Génération ou Replay -->
                    <Border Background="#0D1A2A" BorderBrush="#1E4080" BorderThickness="0,0,0,1"
                            Padding="6,4" Margin="0,0,0,6">
                        <TextBlock Text="⏵ SOURCE DE DONNÉES" Foreground="#00D4FF"
                                   FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                    </Border>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton x:Name="RbGenerate" Grid.Column="0"
                                     Content="Générer" IsChecked="True"
                                     GroupName="EegSource"
                                     Foreground="#E2E8F0" FontFamily="Consolas" FontSize="10"
                                     Checked="RbSource_Changed"/>
                        <RadioButton x:Name="RbReplay" Grid.Column="1"
                                     Content="Replay"
                                     GroupName="EegSource"
                                     Foreground="#E2E8F0" FontFamily="Consolas" FontSize="10"
                                     Checked="RbSource_Changed"/>
                        <RadioButton x:Name="RbLslInlet" Grid.Column="2"
                                     Content="LSL IA"
                                     GroupName="EegSource"
                                     Foreground="#A78BFA" FontFamily="Consolas" FontSize="10"
                                     Checked="RbSource_Changed"/>
                    </Grid>

                    <!-- Panel Replay (visible si RbReplay sélectionné) -->
                    <StackPanel x:Name="PanelReplay" Visibility="Collapsed">
                        <TextBlock Text="FICHIER EEG (.csv ou .bin)" Foreground="#64748B"
                                   FontFamily="Consolas" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtReplayPath" Grid.Column="0"
                                     Background="#0F172A" Foreground="#E2E8F0"
                                     BorderBrush="#1E3A5F" FontFamily="Consolas"
                                     Height="28" Padding="6,4" Text=""/>
                            <Button Grid.Column="1" Content="…" Click="BtnBrowseReplay_Click"
                                    Background="#1E3A5F" Foreground="#E2E8F0"
                                    BorderThickness="0" Margin="3,0,0,0" Height="28"/>
                        </Grid>
                        <TextBlock x:Name="TxtReplayInfo" Text="Sélectionner un fichier..."
                                   Foreground="#475569" FontFamily="Consolas" FontSize="8"
                                   TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="VITESSE" Foreground="#64748B"
                                       FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CbReplaySpeed" Grid.Column="1"
                                      Background="White" Foreground="Black"
                                      FontFamily="Consolas" Height="26"
                                      SelectionChanged="CbReplaySpeed_Changed">
                                <ComboBoxItem Content="0.25×" Tag="0.25"/>
                                <ComboBoxItem Content="0.5×"  Tag="0.5"/>
                                <ComboBoxItem Content="1×"    Tag="1.0" IsSelected="True"/>
                                <ComboBoxItem Content="2×"    Tag="2.0"/>
                                <ComboBoxItem Content="4×"    Tag="4.0"/>
                            </ComboBox>
                        </Grid>
                        <CheckBox x:Name="ChkReplayLoop" Content="Boucler"
                                  Foreground="#E2E8F0" FontFamily="Consolas" FontSize="10"
                                  IsChecked="False" Margin="0,0,0,4"/>

                        <!-- Barre de progression replay -->
                        <Grid Margin="0,0,0,2">
                            <ProgressBar x:Name="PbReplayProgress" Height="8"
                                         Background="#1A2235" Foreground="#00D4FF"
                                         BorderThickness="0" Maximum="100" Value="0"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtReplayProgress" Text="0%"
                                       Foreground="#64748B" FontFamily="Consolas" FontSize="8"/>
                            <Button x:Name="BtnReplayPause" Grid.Column="1"
                                    Content="⏸" Click="BtnReplayPause_Click"
                                    Background="Transparent" Foreground="#00D4FF"
                                    BorderThickness="0" FontSize="14"
                                    Visibility="Collapsed" Cursor="Hand"/>
                        </Grid>
                    </StackPanel>

                    <!-- Panel LSL Inlet (visible si RbLslInlet sélectionné) -->
                    <StackPanel x:Name="PanelLslInlet" Visibility="Collapsed">
                        <Border Background="#120D2A" BorderBrush="#A78BFA" BorderThickness="0,0,0,1"
                                Padding="6,4" Margin="0,0,0,6">
                            <TextBlock Text="⬡ SOURCE LSL EXTERNE (IA)" Foreground="#A78BFA"
                                       FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                        </Border>

                        <!-- Bouton de découverte -->
                        <Button x:Name="BtnDiscoverLsl" Content="🔍  Découvrir les flux LSL"
                                Click="BtnDiscoverLsl_Click" Height="28"
                                Background="#1A0D30" Foreground="#A78BFA"
                                BorderBrush="#4C1D95" BorderThickness="1"
                                FontFamily="Consolas" FontSize="9" Margin="0,0,0,4"
                                Cursor="Hand"/>

                        <!-- Liste des flux disponibles -->
                        <TextBlock Text="FLUX DISPONIBLES" Foreground="#64748B"
                                   FontFamily="Consolas" FontSize="8" FontWeight="Bold"
                                   Margin="0,0,0,3"/>
                        <ListBox x:Name="LstLslStreams"
                                 Background="#0F172A" Foreground="#E2E8F0"
                                 BorderBrush="#1E3A5F" FontFamily="Consolas" FontSize="9"
                                 Height="72" Margin="0,0,0,4"
                                 SelectionChanged="LstLslStreams_SelectionChanged"/>

                        <!-- Info flux sélectionné -->
                        <TextBlock x:Name="TxtLslInletInfo"
                                   Text="Aucun flux sélectionné"
                                   Foreground="#475569" FontFamily="Consolas" FontSize="8"
                                   TextWrapping="Wrap" Margin="0,0,0,4"/>

                        <!-- Statut connexion -->
                        <TextBlock x:Name="TxtLslInletStatus"
                                   Text="○ Non connecté"
                                   Foreground="#64748B" FontFamily="Consolas" FontSize="8"
                                   Margin="0,0,0,6"/>
                    </StackPanel>

                    <!-- ══════ LSL STREAM EEG ══════ -->
                    <Separator Background="#1E3A5F" Margin="0,8,0,8"/>
                    <Border Background="#0A1A0A" BorderBrush="#00FF88" BorderThickness="0,0,0,1"
                            Padding="6,4" Margin="0,0,0,6">
                        <TextBlock Text="⬡ LSL STREAM" Foreground="#00FF88"
                                   FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="ChkLslEeg" Grid.Column="0" Content="EEG"
                                  Foreground="#00FF88" FontFamily="Consolas" FontSize="10"
                                  IsChecked="False" VerticalAlignment="Center" Margin="0,0,6,0"
                                  Checked="ChkLslEeg_Changed" Unchecked="ChkLslEeg_Changed"/>
                        <TextBox x:Name="TxtLslNameEeg" Grid.Column="1"
                                 Background="#0F172A" Foreground="#94A3B8"
                                 BorderBrush="#1E3A5F" FontFamily="Consolas" FontSize="9"
                                 Height="24" Padding="4,2"
                                 Text="BioSynth_EEG"/>
                    </Grid>
                    <TextBlock x:Name="TxtLslStatus" Text="○ LSL inactif"
                               Foreground="#64748B" FontFamily="Consolas" FontSize="8"
                               Margin="0,0,0,8"/>

                    <!-- Bouton EEG -->
                    <Button x:Name="BtnStartStop" Content="▶  DÉMARRER EEG"
                            Click="BtnStartStop_Click" Height="42"
                            FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                            Background="#00C46A" Foreground="#0A0E1A" BorderThickness="0"
                            Margin="0,0,0,4"/>

                    <!-- Statut + compteurs EEG -->
                    <Border Background="#0F172A" BorderBrush="#1E3A5F" BorderThickness="1"
                            Margin="0,0,0,4" Padding="8,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="STATUT" Foreground="#64748B" FontFamily="Consolas"
                                           FontSize="8" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtStatus" Text="Prêt"
                                           Foreground="#00FF88" FontFamily="Consolas" FontSize="10"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="SAMPLES" Foreground="#64748B" FontFamily="Consolas"
                                           FontSize="8" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtSampleCount" Text="0"
                                           Foreground="#00D4FF" FontFamily="Consolas"
                                           FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="DURÉE" Foreground="#64748B" FontFamily="Consolas"
                                           FontSize="8" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtDuration" Text="0.0s"
                                           Foreground="#8B5CF6" FontFamily="Consolas"
                                           FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="SOURCE" Foreground="#64748B" FontFamily="Consolas"
                                           FontSize="8" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtSourceMode" Text="GÉN."
                                           Foreground="#00FF88" FontFamily="Consolas"
                                           FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="REPLAY" Foreground="#64748B" FontFamily="Consolas"
                                           FontSize="8" FontWeight="Bold" Margin="0,3,0,0"/>
                                <TextBlock x:Name="TxtReplayFrame" Text="—"
                                           Foreground="#00D4FF" FontFamily="Consolas"
                                           FontSize="10" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtReplayPct" Text=""
                                           Foreground="#8B5CF6" FontFamily="Consolas" FontSize="9"/>
                            </StackPanel>
                        </Grid>
