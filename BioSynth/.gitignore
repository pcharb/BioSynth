# ═══════════════════════════════════════════════════════
#  BioSynth — .gitignore
#  C# · WPF · .NET 8 · Windows
# ═══════════════════════════════════════════════════════

# ── Build & compilation ──────────────────────────────────
bin/
obj/
out/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
*.dll
!Assets/brain.mtl         # garder les assets du projet
*.exe
*.pdb
*.pdb.zip
*.ilk
*.exp
*.lib
*.cache
*.user
*.suo
.vs/

# ── NuGet & packages ────────────────────────────────────
packages/
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
artifacts/
**/[Pp]ackages/*

# ── Fichiers de config IDE ───────────────────────────────
.vs/
*.user
*.userosscache
*.sln.docstates
*.suo
.idea/
*.DotSettings
*.DotSettings.user
.vscode/
*.swp
*.bak
*~

# ── Données enregistrées (gros fichiers EEG) ────────────
*.bin
*.eeg
*.xdf
*.csv
*.fif
*.set
*.edf
*.bdf

# ── Assets 3D lourds — à gérer via Git LFS ──────────────
Assets/*.obj
Assets/*.fbx
Assets/*.blend
Assets/*.stl
Assets/*.ply
Assets/*.3ds
# Garder la texture et le MTL légers
!Assets/brain.mtl
!Assets/brain_tex.jpg

# ── LSL — DLL native (à télécharger séparément) ─────────
lsl.dll
liblsl.dll
liblsl64.dll
liblsl*.dll

# ── Fichiers temporaires système ─────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.stackdump
*.DS_Store

# ── Logs & diagnostics ───────────────────────────────────
*.log
*.trace
crash-*.txt

# ── Sorties de présentation & rapports ───────────────────
*.pptx
*.pdf
*.docx

# ── Tests & couverture ───────────────────────────────────
TestResults/
coverage/
*.coverage
*.coveragexml
